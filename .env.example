# Copia este archivo como .env para desarrollo local
# NUNCA subas .env al repositorio

SUPABASE_URL=https://XXXXXXXXXX.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# CORS — dominio exacto del frontend (sin trailing slash)
# En producción: https://tu-app.vercel.app
# En desarrollo: dejar vacío para permitir cualquier origen
ALLOWED_ORIGIN=

# Puerto local (opcional, por defecto 3000)
# PORT=3000
